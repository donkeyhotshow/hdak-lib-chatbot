# ─── OAuth / Auth ──────────────────────────────────────────────────────────────
# Application ID from the Manus Developer Console
VITE_APP_ID=

# Secret used to sign session cookies (any long random string, e.g. openssl rand -hex 32)
JWT_SECRET=

# Base URL of the Manus OAuth server (e.g. https://oauth.example.com)
OAUTH_SERVER_URL=

# OpenID of the user who should automatically receive the "admin" role on first login
OWNER_OPEN_ID=

# Full URL for the OAuth login/portal page shown to unauthenticated users
# e.g. https://oauth.example.com
VITE_OAUTH_PORTAL_URL=

# ─── Database ──────────────────────────────────────────────────────────────────
# MySQL connection string. If omitted, the server falls back to in-memory mock data.
# Conversations and messages are unavailable without a real database.
# Format: mysql://user:password@host:3306/dbname
DATABASE_URL=
# Set to "true" only when your PostgreSQL uses a self-signed certificate and
# certificate verification is not possible (e.g. some non-Render setups).
# Render's built-in PostgreSQL does NOT require this flag.
DATABASE_SSL_NO_VERIFY=

# ─── Docker Compose (optional overrides) ──────────────────────────────────────
# Override the bundled MySQL container credentials.
# docker-compose.yml uses these values; defaults are hdak / hdakpassword / hdak_chatbot.
# Change them for internet-facing deployments.
# MYSQL_ROOT_PASSWORD=rootpassword
# MYSQL_DATABASE=hdak_chatbot
# MYSQL_USER=hdak
# MYSQL_PASSWORD=hdakpassword

# ─── AI / LLM ──────────────────────────────────────────────────────────────────
# Primary provider (Gemini — free forever)
# Base URL of the OpenAI-compatible API endpoint
BUILT_IN_FORGE_API_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Bearer token / API key for the primary provider
BUILT_IN_FORGE_API_KEY=AIza...

# LLM model name for the primary provider.
# Default: gpt-4o-mini (works with most OpenAI-compatible proxies)
LLM_MODEL=gemini-1.5-flash

# ─── Fallback AI provider (optional) ──────────────────────────────────────────
# When the primary provider fails (rate limit, timeout, API error), the chat
# endpoint automatically retries with this provider.  Leave blank to disable.
# Example below uses Groq (generous free tier):
FALLBACK_API_URL=https://api.groq.com/openai/v1
FALLBACK_API_KEY=gsk_...
# Model name for the fallback provider. Default: llama-3.1-8b-instant
FALLBACK_MODEL=llama-3.1-8b-instant

# ─── Server ────────────────────────────────────────────────────────────────────
# HTTP port (default: 3000; the server auto-increments if the port is busy)
PORT=3000

# Runtime environment; controls logging verbosity and Vite dev middleware
# Allowed values: "development" | "production"
NODE_ENV=development

# ── Render keep-alive workflow ─────────────────────────────────────────────
# Store this as a GitHub repository secret (Settings → Secrets → Actions)
# named RENDER_APP_URL so the keep-alive.yml workflow can ping your service.
# Example value: https://hdak-lib-chatbot.onrender.com
# RENDER_APP_URL=https://your-app.onrender.com
