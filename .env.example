# ─── OAuth / Auth ──────────────────────────────────────────────────────────────
# Application ID from the Manus Developer Console
VITE_APP_ID=

# Secret used to sign session cookies (any long random string, e.g. openssl rand -hex 32)
JWT_SECRET=

# Base URL of the Manus OAuth server (e.g. https://oauth.example.com)
OAUTH_SERVER_URL=

# OpenID of the user who should automatically receive the "admin" role on first login
OWNER_OPEN_ID=

# Full URL for the OAuth login/portal page shown to unauthenticated users
# e.g. https://oauth.example.com
VITE_OAUTH_PORTAL_URL=

# ─── Database ──────────────────────────────────────────────────────────────────
# MySQL connection string. If omitted, the server falls back to in-memory mock data.
# Conversations and messages are unavailable without a real database.
# Format: mysql://user:password@host:3306/dbname
DATABASE_URL=

# Optional Redis URL for distributed cache/rate-limit/session backends
# (e.g. Upstash Redis "redis://default:<password>@<host>:<port>")
REDIS_URL=

# ─── Docker Compose (optional overrides) ──────────────────────────────────────
# Override the bundled MySQL container credentials.
# docker-compose.yml uses these values; defaults are hdak / hdakpassword / hdak_chatbot.
# Change them for internet-facing deployments.
# MYSQL_ROOT_PASSWORD=rootpassword
# MYSQL_DATABASE=hdak_chatbot
# MYSQL_USER=hdak
# MYSQL_PASSWORD=hdakpassword

# ─── AI / LLM ──────────────────────────────────────────────────────────────────
# Base URL of the OpenAI-compatible API endpoint
# (either BUILT_IN_FORGE_API_URL or FORGE_API_URL can be used).
# The server appends /v1 automatically when a versioned path is not present.
# For Google Gemini (free): https://generativelanguage.googleapis.com/v1beta/openai
# For OpenRouter: https://openrouter.ai/api/v1
BUILT_IN_FORGE_API_URL=
FORGE_API_URL=

# Bearer token / API key for the above endpoint.
# Priority: BUILT_IN_FORGE_API_KEY -> FORGE_API_KEY -> OPENAI_API_KEY
BUILT_IN_FORGE_API_KEY=
FORGE_API_KEY=
OPENAI_API_KEY=

# Optional provider key for external chat proxy adapters.
# Leave blank unless you run a separate chat provider gateway.
CHAT_PROVIDER_API_KEY=

# Optional OpenRouter metadata headers (only used when set).
# OPENROUTER_HTTP_REFERER example: https://your-app.example.com
# OPENROUTER_X_TITLE example: HDAK Library Chatbot
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=

# Browser-side Maps proxy settings (used by client/src/components/Map.tsx).
# These are optional unless you use the map feature in the UI.
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev
VITE_FRONTEND_FORGE_API_KEY=

# LLM model name (default: gemini-2.0-flash)
# Examples: gemini-2.0-flash, openrouter/auto, google/gemini-2.0-flash-exp:free
AI_MODEL_NAME=gemini-2.0-flash

# ─── Server ────────────────────────────────────────────────────────────────────
# HTTP port (default: 3000; the server auto-increments if the port is busy)
PORT=3000

# Runtime environment; controls logging verbosity and Vite dev middleware
# Allowed values: "development" | "production"
NODE_ENV=development
