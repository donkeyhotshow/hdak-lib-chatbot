# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Groq (Primary LLM provider)
GROQ_API_KEY=gsk_...
GROQ_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# Qwen via DashScope (Fallback LLM provider)
QWEN_API_KEY=sk-...
QWEN_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_MODEL_NAME=qwen-turbo

# Upstash Redis (Rate Limiting — production only, optional)
# Get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxx-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# Catalog API endpoints
CATALOG_URL=https://library-service.com.ua:8443/khkhdak/DocumentSearchResult
CATALOG_FORM_URL=https://library-service.com.ua:8443/khkhdak/DocumentSearchForm

# Cleanup endpoint secret (optional)
CLEANUP_SECRET=your-secret-here

# Push notifications (Web Push / VAPID)
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:abon@xdak.ukr.education
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Cron secret for /api/push/remind endpoint
CRON_SECRET=your-cron-secret-here

# Public site URL (used for metadata/sitemap)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
