# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Required. Neon serverless Postgres connection string.
# Get it from https://console.neon.tech → your project → Connection string.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ─── LLM providers ────────────────────────────────────────────────────────────
# At least one of GROQ_API_KEY or QWEN_API_KEY must be set.
# Groq (primary) — https://console.groq.com/keys
GROQ_API_KEY=
# Override defaults only when using a self-hosted/alternative Groq-compatible endpoint:
# GROQ_URL=https://api.groq.com/openai/v1/chat/completions
# GROQ_MODEL_NAME=llama-3.3-70b-versatile

# Qwen (fallback) — https://dashscope.aliyuncs.com
QWEN_API_KEY=
# QWEN_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
# QWEN_MODEL_NAME=qwen-turbo

# ─── Rate limiting (Upstash Redis) ────────────────────────────────────────────
# Optional. Falls back to in-memory sliding window when not set.
# Create a free Redis DB at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Library catalog ──────────────────────────────────────────────────────────
# Optional. Defaults to the ХДАК public catalog endpoint if not set.
# CATALOG_URL=https://library-service.com.ua:8443/khkhdak/DocumentSearchResult
# CATALOG_FORM_URL=https://library-service.com.ua:8443/khkhdak/DocumentSearchForm

# ─── Push notifications (VAPID) ───────────────────────────────────────────────
# Required for book-return reminders. Generate a VAPID key pair:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Subject must be a mailto: or https: URL
VAPID_SUBJECT=mailto:library@hdak.edu.ua

# ─── Cron / cleanup secrets ───────────────────────────────────────────────────
# Protect POST /api/push/remind — set in Vercel dashboard and Vercel Cron config.
CRON_SECRET=
# Protect POST /api/cleanup (delete conversations older than 90 days).
CLEANUP_SECRET=
