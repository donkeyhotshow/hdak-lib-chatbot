# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# AI Providers (OpenRouter - Primary)
BUILT_IN_FORGE_API_KEY=sk-or-v1-...
BUILT_IN_FORGE_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_MODEL_NAME=openai/gpt-4o-mini

# Groq (Fallback)
GROQ_API_KEY=gsk_...
GROQ_MODEL_NAME=llama-3.1-8b-instant

# AI Providers (OpenAI - Secondary Fallback)
OPENAI_API_KEY=sk-...

# AI Providers (Google Gemini - Tertiary Fallback)
GOOGLE_GENERATIVE_AI_API_KEY=...

# App Config
OPENROUTER_HTTP_REFERER=https://hdak-lib-chatbot.vercel.app
OPENROUTER_X_TITLE=HDAK Library Chatbot

# Upstash Redis (Rate Limiting — production)
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxx-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...
